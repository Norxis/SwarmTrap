<clickhouse>
    <!-- System log TTL ring — deployed 2026-03-19 -->
    <!-- High-volume logs: 3 days -->
    <text_log>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </text_log>
    <trace_log>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </trace_log>
    <processors_profile_log>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </processors_profile_log>
    <asynchronous_metric_log>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </asynchronous_metric_log>

    <!-- Standard logs: 7 days -->
    <query_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </query_log>
    <query_views_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </query_views_log>
    <part_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </part_log>
    <metric_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </metric_log>
    <asynchronous_insert_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </asynchronous_insert_log>
    <query_metric_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </query_metric_log>
    <background_schedule_pool_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </background_schedule_pool_log>
    <error_log>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </error_log>
</clickhouse>
